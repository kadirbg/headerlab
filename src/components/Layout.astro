---
interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const siteUrl = "https://headerlab.dev";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical ?? siteUrl} />

<!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical ?? siteUrl} />
    <meta property="og:site_name" content="HeaderLab" />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="HeaderLab — Modern web security toolkit" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />
    <meta name="twitter:image:alt" content="HeaderLab — Modern web security toolkit" />

    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href="/" class="logo">
          <span class="logo-bracket">[</span><span class="logo-text">HeaderLab</span><span class="logo-bracket">]</span>
        </a>
        <ul class="nav-links">
          <li><a href="/headers">Headers Checker</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="https://github.com/kadirbg/headerlab" target="_blank" rel="noopener">GitHub</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>HeaderLab — Free, privacy-first web security tools.</p>
      <p><a href="https://github.com/kadirbg/headerlab">Open source on GitHub</a></p>
    </footer>

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; }

      :root {
        --bg: #0a0e1a;
        --bg-elev: #111827;
        --bg-elev-2: #1a2233;
        --border: #1f2937;
        --text: #e5e7eb;
        --text-dim: #9ca3af;
        --text-faint: #6b7280;
        --accent: #38bdf8;
        --accent-bright: #7dd3fc;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
        --font-mono: 'JetBrains Mono', 'Fira Code', Consolas, monospace;
      }

      html {
        font-family: var(--font-sans);
        background: var(--bg);
        color: var(--text);
        -webkit-font-smoothing: antialiased;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      main {
        flex: 1;
        max-width: 1100px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
        width: 100%;
      }

      .site-header {
        border-bottom: 1px solid var(--border);
      }

      .site-header nav {
        max-width: 1100px;
        margin: 0 auto;
        padding: 1rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
      }

      .logo {
        font-family: var(--font-mono);
        font-size: 1.1rem;
        font-weight: 600;
        text-decoration: none;
        color: var(--text);
      }

      .logo-bracket {
        color: var(--accent);
      }

      .nav-links {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        gap: 1.5rem;
      }

      .nav-links a {
        color: var(--text-dim);
        text-decoration: none;
        font-size: 0.95rem;
        transition: color 0.15s;
      }

      .nav-links a:hover {
        color: var(--accent);
      }

      .site-footer {
        border-top: 1px solid var(--border);
        padding: 2rem 1.5rem;
        text-align: center;
        font-size: 0.85rem;
        color: var(--text-faint);
      }

      .site-footer p { margin: 0.25rem 0; }
      .site-footer a { color: var(--text-dim); }

      h1, h2, h3 { margin-top: 0; }
      a { color: var(--accent); }

      code {
        font-family: var(--font-mono);
        background: var(--bg-elev);
        padding: 0.15rem 0.4rem;
        border-radius: 4px;
        font-size: 0.9em;
      }

      /* ===== Shared tool-page styles ===== */
      .tool-header { padding: 2rem 0 1rem; }

      .back-link {
        color: var(--text-faint);
        text-decoration: none;
        font-size: 0.9rem;
      }
      .back-link:hover { color: var(--accent); }

      .tool-header h1 {
        font-size: 2rem;
        margin: 1rem 0 0.5rem;
      }

      .lead {
        color: var(--text-dim);
        line-height: 1.6;
        max-width: 700px;
      }

      /* ===== Fix snippets (Nginx/Apache/Cloudflare tabs) ===== */
      .fix-snippets { margin: 1rem 0 0.75rem; }

      .fix-snippets h4 {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-faint);
        margin: 0 0 0.5rem;
        font-family: var(--font-mono);
        font-weight: 600;
      }

      .fix-snippets .tabs {
        display: flex;
        gap: 0.25rem;
        border-bottom: 1px solid var(--border);
      }

      .fix-snippets .tab-btn {
        background: transparent;
        border: 1px solid transparent;
        border-bottom: none;
        color: var(--text-faint);
        padding: 0.5rem 0.9rem;
        font-size: 0.85rem;
        font-family: var(--font-mono);
        cursor: pointer;
        border-radius: 6px 6px 0 0;
        margin-bottom: -1px;
        transition: all 0.15s;
      }
      .fix-snippets .tab-btn:hover { color: var(--text); }
      .fix-snippets .tab-btn.active {
        color: var(--accent);
        background: var(--bg-elev-2);
        border-color: var(--border);
      }

      .tab-panels { position: relative; }
      .tab-panel { display: none; }
      .tab-panel.active { display: block; }

      .snippet-location {
        background: rgba(56, 189, 248, 0.06);
        border-left: 2px solid var(--accent);
        color: var(--text-dim);
        padding: 0.65rem 0.9rem;
        border-radius: 6px;
        font-size: 0.85rem;
        line-height: 1.55;
        margin-bottom: 0.5rem;
      }
      .snippet-location strong { color: var(--text); font-weight: 600; margin-right: 0.25rem; }
      .snippet-location code {
        background: var(--bg);
        padding: 0.1rem 0.35rem;
        border-radius: 3px;
        font-size: 0.85em;
        color: var(--accent-bright);
        font-family: var(--font-mono);
      }

      .snippet-code { position: relative; }

      .snippet-code pre {
        background: var(--bg-elev-2);
        border: 1px solid var(--border);
        border-radius: 0 8px 8px 8px;
        padding: 1rem;
        padding-right: 5rem;
        overflow-x: auto;
        margin: 0;
        font-size: 0.85rem;
        line-height: 1.55;
      }
      .snippet-code pre code {
        background: none;
        padding: 0;
        font-family: var(--font-mono);
        color: var(--text);
        white-space: pre;
      }

      .copy-btn {
        position: absolute;
        top: 0.65rem;
        right: 0.65rem;
        background: var(--bg-elev);
        border: 1px solid var(--border);
        color: var(--text-dim);
        padding: 0.3rem 0.75rem;
        font-size: 0.75rem;
        font-family: var(--font-mono);
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.15s;
        z-index: 1;
      }
      .copy-btn:hover { color: var(--text); border-color: var(--text-dim); }
      .copy-btn.copied { color: var(--success); border-color: var(--success); }
    </style>
  </body>
</html>